VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Garmin Connect credentials (server-side only — never bundled into the frontend).
#
# GARMIN_TOKEN  — Serialized DI token JSON. Fastest: no SSO round-trip on each
#                 cron run. Generate from a machine with a cached session:
#                   python -c "
#                   import os; from garminconnect import Garmin
#                   g = Garmin(); g.client.load(os.path.expanduser('~/.garminconnect'))
#                   print(g.client.dumps())
#                   "
#                 When the token expires, the sync falls back to email/password
#                 and returns a new_token in its response — paste that value here.
#
# GARMIN_EMAIL / GARMIN_PASSWORD — Fallback credentials used when GARMIN_TOKEN
#                 is absent or has expired. Account must NOT have MFA enabled.
#                 Also used by scripts/garmin_sync.py (which CAN handle MFA).
GARMIN_TOKEN=
GARMIN_EMAIL=
GARMIN_PASSWORD=
